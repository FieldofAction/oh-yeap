# Copy this file to .env.local and fill in real Stripe Payment Link URLs.
# .env.local is gitignored — never commit the real URLs.
#
# See scripts/nest/STRIPE-SETUP.md for how to create the Payment Links.

# NEST release Stripe Payment Links
VITE_STRIPE_POSTER_URL=https://buy.stripe.com/REPLACE_ME
VITE_STRIPE_TEE_URL=https://buy.stripe.com/REPLACE_ME
VITE_STRIPE_TOTE_URL=https://buy.stripe.com/REPLACE_ME
VITE_STRIPE_BUNDLE_URL=https://buy.stripe.com/REPLACE_ME
